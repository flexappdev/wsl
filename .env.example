# WSL — World Stats Live

# Mongo (read-only). Optional — the site falls back to seed data when unset.
MONGO_URI=
MONGO_DB=AIDB

# Supabase — required only for /bo admin gate.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: service role for backoffice mutations (not used in this round).
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL — used by sitemap.xml, robots.txt, and OG metadata.
# Leave unset locally; in prod set to the canonical URL (e.g. https://worldstats.live).
NEXT_PUBLIC_SITE_URL=
