# WSL — World Stats Live

# Mongo (read-only). Optional — the site falls back to seed data when unset.
MONGO_URI=
MONGO_DB=AIDB

# Supabase — required only for /bo admin gate.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: service role for backoffice mutations (not used in this round).
SUPABASE_SERVICE_ROLE_KEY=
